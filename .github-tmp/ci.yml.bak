name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  test:
    name: Test on Node ${{ matrix.node }}
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        node: ['18', '20', '22']
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node }}
          cache: 'npm'
      - name: Install
        run: npm install --no-audit --no-fund
      - name: Lint (syntax check)
        run: npm run lint
      - name: Test
        run: npm test
      - name: Smoke test (init + doctor)
        run: |
          node bin/codex-toolkit.js init --dry-run
          CODEX_HOME="$(mktemp -d)" node bin/codex-toolkit.js init
          CODEX_HOME="$(ls -td "$RUNNER_TEMP"/*/ | head -1)" node bin/codex-toolkit.js doctor || true
